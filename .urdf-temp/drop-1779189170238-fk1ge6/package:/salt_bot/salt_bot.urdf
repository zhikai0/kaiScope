<?xml version="1.0" encoding="utf-8"?>
<robot name="salt_ackbot" xmlns:xacro="http://www.ros.org/wiki/xacro" >

  <material name="vehicle_material">
    <texture filename="file://$(find ackbot)/robots/salt_bot/assets/material/vehicle.png"/>
  </material>
  <material name="rake_material">
    <texture filename="file://$(find ackbot)/robots/salt_bot/assets/material/rake.png"/>
  </material>

  <link name="base_link">
        <visual>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
              <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/vehicle.dae" />
          </geometry>
          <material name="vehicle_material"/>
      </visual>
      <collision>
      <origin xyz="0.8 0 1.1" rpy="0 0 0" /> 
      <geometry>
        <box size="3.135 0.8 1.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0 0.63 0.7" rpy="0 0 0"/>
    <axis xyz="0.00000 1.00000 0.00000"/>
  </joint>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 -0.63 -0.7" rpy="0 0 0" /> 
      <geometry>
        <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/rear_left_wheel.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" /> 
      <geometry>
        <cylinder radius="0.7" length="0.3"/>
      </geometry>
    </collision>
  </link>
  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0 -0.63 0.7" rpy="0 0 0"/>
    <axis xyz="0.00000 1.00000 0.00000"/>
  </joint>
  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0.63 -0.7" rpy="0 0 0" /> 
      <geometry>
        <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/rear_right_wheel.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" /> 
      <geometry>
        <cylinder radius="0.7" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_left_steering_joint" type="revolute">
    <limit lower="-0.5236" upper="0.5236" effort="100.0" velocity="5.0"/>
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="1.6 0.64 0.613" rpy="0 0 0"/>
    <axis xyz="0.00000 0.00000 1.00000"/>
  </joint>
  <link name="front_left_wheel">
    <visual>
      <origin xyz="-1.6 -0.64 -0.613" rpy="0 0 0" /> 
      <geometry>
        <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/front_left_wheel.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" /> 
      <geometry>
        <cylinder radius="0.613" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_right_steering_joint" type="revolute">
    <limit lower="-0.5236" upper="0.5236" effort="100.0" velocity="5.0"/>
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="1.6 -0.64 0.613" rpy="0 0 0"/>
    <axis xyz="0.00000 0.00000 1.00000"/>
  </joint>
  <link name="front_right_wheel">
    <visual>
      <origin xyz="-1.6 0.64 -0.613" rpy="0 0 0" /> 
      <geometry>
        <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/front_right_wheel.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" /> 
      <geometry>
        <cylinder radius="0.613" length="0.3"/>
      </geometry>
    </collision>
  </link>
  <joint name="rake_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rake"/>
    <origin xyz="-0.7 0 1.0" rpy="0 0 0"/>
  </joint>
  <link name="rake">
    <visual>
      <origin xyz="0.7 0 -1.0" rpy="0 0 0" /> 
      <geometry>
        <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/rake1.dae" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.7 0 -1.0" rpy="0 0 0" /> 
      <geometry>
          <mesh filename="file://$(find ackbot)/robots/salt_bot/assets/meshes/dae/rake1.dae" />
      </geometry>
    </collision>
  </link>

</robot>

