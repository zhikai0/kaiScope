<mujoco model="salt_ackbot">
  <option iterations="50" timestep="0.001" solver="PGS" gravity="0 0 -9.81" />

  <compiler angle="radian" meshdir="assets/meshes/obj" eulerseq="zyx" autolimits="true" />

  <default>
    <joint limited="true" damping="0.01" armature="0.01" frictionloss="0.01" />
    <geom condim="4" contype="1" conaffinity="15" friction="0.9 0.2 0.2" solref="0.001 2" />
    <motor ctrllimited="true" />
    <equality solref="0.001 2" />
  </default>

  <worldbody>
    <light directional="true" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false" />
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1" />
    <geom name="ground" type="plane" pos="0 0 0" size="100 100 0.001" quat="1 0 0 0" material="matplane" condim="3" conaffinity="15" />
    <camera name="fixed" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    <camera name="track" mode="trackcom" pos="0 -3.0 0.5" xyaxes="1 0 0 0 0 1" />
    
    <body name="root" pos="0 0 -0.0" quat="1 0 0 0">
      <freejoint name="root" />
      
      <!-- 车身碰撞几何体 -->
      <!-- <geom name="base_collision" size="1.5675 0.4 0.525" pos="0.8 0 1.1" type="box" contype="1" conaffinity="0" density="0" group="1" /> -->
      
      <!-- 车身视觉mesh - 纯可视化，无物理属性 -->
      <geom name="base_visual" type="mesh" mesh="vehicle_mesh" pos="0 0 0" group="0" material="vehicle_material" />
      
      <!-- 后左轮 -->
      <body name="rear_left_wheel" pos="0 0 0">
        <joint name="rear_left_wheel_joint" pos="0 0.63 0.7" axis="0 1 0" limited="false" />
        <!-- 轮子碰撞几何体 -->
        <!-- <geom name="rear_left_collision" size="0.7 0.15" quat="0.707105 0.707108 0 0" type="cylinder" contype="1" conaffinity="0" density="0" group="1" /> -->
        <!-- 轮子视觉mesh - 纯可视化，无物理属性 -->
        <geom name="rear_left_visual" type="mesh" mesh="rear_left_wheel_mesh" pos="0 0 0" group="0" />
      </body>
      
      <!-- 后右轮 -->
      <body name="rear_right_wheel" pos="0 0 0">
        <joint name="rear_right_wheel_joint" pos="0 -0.63 0.7" axis="0 1 0" limited="false" />
        <!-- 轮子碰撞几何体 -->
        <!-- <geom name="rear_right_collision" size="0.7 0.15" quat="0.707105 0.707108 0 0" type="cylinder" contype="1" conaffinity="0" density="0" group="1" /> -->
        <!-- 轮子视觉mesh - 纯可视化，无物理属性 -->
        <geom name="rear_right_visual" type="mesh" mesh="rear_right_wheel_mesh" pos="0 0 0" group="0" />
      </body>
      
      <!-- 前左轮 -->
      <body name="front_left_wheel" pos="0 0 0 ">
        <joint name="front_left_steering_joint" pos="1.6 0.64 0.613" axis="0 0 1" range="-0.5236 0.5236" actuatorfrcrange="-100 100" />
        <!-- 轮子碰撞几何体 -->
        <!-- <geom name="front_left_collision" size="0.613 0.15" quat="0.707105 0.707108 0 0" type="cylinder" contype="1" conaffinity="0" density="0" group="1" /> -->
        <!-- 轮子视觉mesh - 纯可视化，无物理属性 -->
        <geom name="front_left_visual" type="mesh" mesh="front_left_wheel_mesh" pos="0 0 0" group="0" />
      </body>
      
      <!-- 前右轮 -->
      <body name="front_right_wheel" pos="0 0 0">
        <joint name="front_right_steering_joint" pos="1.6 -0.64 0.613" axis="0 0 1" range="-0.5236 0.5236" actuatorfrcrange="-100 100" />
        <!-- 轮子碰撞几何体 -->
        <!-- <geom name="front_right_collision" size="0.613 0.15" quat="0.707105 0.707108 0 0" type="cylinder" contype="1" conaffinity="0" density="0" group="1" /> -->
        <!-- 轮子视觉mesh - 纯可视化，无物理属性 -->
        <geom name="front_right_visual" type="mesh" mesh="front_right_wheel_mesh" pos="0 0 0" group="0" />
      </body>
      
      <!-- 耙子 -->
      <body name="rake" pos="-0.7 0 1.0">
        <!-- 耙子碰撞几何体 -->
        <!-- <geom name="rake_collision" size="0.25 0.05 0.4" pos="0.7 0 -1.0" type="box" contype="1" conaffinity="0" density="0" group="1" /> -->
        <!-- 耙子视觉mesh - 纯可视化，无物理属性 -->
        <geom name="rake_visual" type="mesh" mesh="rake_mesh" pos="0.7 0 -1.0" group="0" material="rake_material" />
      </body>
    </body>
  </worldbody>

  <asset>
    <!-- 地面纹理 -->
    <texture name="texplane" type="2d" builtin="checker" rgb1=".0 .0 .0" rgb2=".8 .8 .8" width="100" height="100" />
    <material name="matplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true" />
    
    <!-- 车身材质 -->
    <texture name="vehicle_texture" type="2d" file="assets/material/vehicle.png" />
    <material name="vehicle_material" texture="vehicle_texture" />
    
    <!-- 耙子材质 -->
    <texture name="rake_texture" type="2d" file="assets/material/rake.png" />
    <material name="rake_material" texture="rake_texture" />
    
    <!-- Mesh资源 -->
    <mesh name="vehicle_mesh" file="vehicle.obj" />
    <mesh name="rear_left_wheel_mesh" file="rear_left_wheel.obj" />
    <mesh name="rear_right_wheel_mesh" file="rear_right_wheel.obj" />
    <mesh name="front_left_wheel_mesh" file="front_left_wheel.obj" />
    <mesh name="front_right_wheel_mesh" file="front_right_wheel.obj" />
    <mesh name="rake_mesh" file="rake.obj" />
  </asset>

  <actuator>
    <motor name="rear_left_wheel_joint" joint="rear_left_wheel_joint" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="rear_right_wheel_joint" joint="rear_right_wheel_joint" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="front_left_steering_joint" joint="front_left_steering_joint" ctrllimited="true" ctrlrange="-100 100" gear="1" />
    <motor name="front_right_steering_joint" joint="front_right_steering_joint" ctrllimited="true" ctrlrange="-100 100" gear="1" />
  </actuator>

  <sensor>
    <actuatorpos name="rear_left_wheel_joint_p" actuator="rear_left_wheel_joint" />
    <actuatorvel name="rear_left_wheel_joint_v" actuator="rear_left_wheel_joint" />
    <actuatorfrc name="rear_left_wheel_joint_f" actuator="rear_left_wheel_joint" noise="0.001" />
    <actuatorpos name="rear_right_wheel_joint_p" actuator="rear_right_wheel_joint" />
    <actuatorvel name="rear_right_wheel_joint_v" actuator="rear_right_wheel_joint" />
    <actuatorfrc name="rear_right_wheel_joint_f" actuator="rear_right_wheel_joint" noise="0.001" />
    <actuatorpos name="front_left_steering_joint_p" actuator="front_left_steering_joint" />
    <actuatorvel name="front_left_steering_joint_v" actuator="front_left_steering_joint" />
    <actuatorfrc name="front_left_steering_joint_f" actuator="front_left_steering_joint" noise="0.001" />
    <actuatorpos name="front_right_steering_joint_p" actuator="front_right_steering_joint" />
    <actuatorvel name="front_right_steering_joint_v" actuator="front_right_steering_joint" />
    <actuatorfrc name="front_right_steering_joint_f" actuator="front_right_steering_joint" noise="0.001" />
  </sensor>
</mujoco>